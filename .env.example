# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=capitalhouse
POSTGRES_PASSWORD=capitalhouse_dev
POSTGRES_DB=capitalhouse
DATABASE_URL=postgresql+asyncpg://capitalhouse:capitalhouse_dev@localhost:5432/capitalhouse

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_dev
REDIS_URL=redis://:redis_dev@localhost:6379/0

# ─── Meilisearch ───────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=meilisearch_dev_key
MEILI_URL=http://localhost:7700

# ─── Twilio (SMS / OTP) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Cloudflare R2 (Media Storage) ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=capital-house-media
R2_PUBLIC_URL=

# ─── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── MyFatoorah (Payments) ─────────────────────────────────────────────────────
MYFATOORAH_API_KEY=
MYFATOORAH_BASE_URL=https://apitest.myfatoorah.com

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MEILI_URL=http://localhost:7700
NEXT_PUBLIC_MEILI_SEARCH_KEY=
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
